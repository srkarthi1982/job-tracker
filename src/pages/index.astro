---
import { AvButton, AvCard, AvContainer, AvTimeline } from "@ansiversa/components";
import AppShell from "../layouts/AppShell.astro";

const title = "Job Tracker – Ansiversa";
const description = "Track your job search pipeline from wishlist to accepted offer.";

if (Astro.locals.isAuthenticated || Astro.locals.user?.id) {
  return Astro.redirect("/app/job-applications");
}

const stageFlow = [
  { name: "Wishlist", detail: "Capture interesting roles before they disappear." },
  { name: "Applied", detail: "Log where you have already submitted." },
  { name: "Interview", detail: "Keep conversations and prep milestones visible." },
  { name: "Offer", detail: "Track live opportunities and decision timing." },
  { name: "Accepted / Rejected", detail: "Close the loop with a clean outcome history." },
];

const pillars = [
  {
    title: "Pipeline-first tracking",
    body: "Move every application through clear stages instead of juggling tabs and spreadsheets.",
  },
  {
    title: "Fast status updates",
    body: "Quick edits keep your search current without turning tracking into extra work.",
  },
  {
    title: "Clean review history",
    body: "Notes, follow-ups, and stage changes stay attached to the right application.",
  },
  {
    title: "Weekly review clarity",
    body: "See where momentum is building and where follow-up discipline is slipping.",
  },
  {
    title: "Better than spreadsheets",
    body: "Stay organized with a purpose-built workflow instead of loose rows and manual formulas.",
  },
  {
    title: "Search momentum visibility",
    body: "Know what is active, what is stalled, and what needs your next action.",
  },
];

const workflowItems = [
  {
    date: "Step 01",
    title: "Add an application",
    body: "Start with company, role, applied date, and the stage that matches your current position.",
  },
  {
    date: "Step 02",
    title: "Update stages and notes",
    body: "Capture interviews, follow-ups, and context as the application moves forward.",
  },
  {
    date: "Step 03",
    title: "Review progress and next steps",
    body: "Use the tracker as your weekly control panel for momentum, timing, and follow-through.",
  },
];
---

<AppShell title={title} description={description}>
  <section class="av-hero">
    <AvContainer size="default">
      <div class="av-hero__grid">
        <div class="av-hero__content av-auth-stack-md">
          <div class="av-kicker">
            <span>Career · Ansiversa Mini App</span>
          </div>
          <h1 class="av-section-title">Job Tracker</h1>
          <p class="av-section-lead">
            Track applications from wishlist to final outcome with a clean pipeline built for real job search follow-through.
          </p>
          <ul class="av-list">
            <li>Keep every role visible from first save to final decision</li>
            <li>Update statuses, interviews, and notes without spreadsheet clutter</li>
            <li>Review search momentum and next steps in one focused flow</li>
          </ul>
          <div class="av-row-wrap">
            <AvButton href="/app/job-applications">Open Job Tracker</AvButton>
            <AvButton href="/help" variant="ghost">Help</AvButton>
          </div>
          <p class="av-text-soft">Built for organized search rhythm, not zero-data dashboard noise.</p>
        </div>

        <AvCard variant="soft" className="av-auth-stack-sm">
          <p class="av-kicker">Stage flow</p>
          <h2 class="av-card-heading">A simple pipeline for the full search</h2>
          <ol class="av-list">
            {stageFlow.map((stage) => (
              <li>
                <strong>{stage.name}</strong> — {stage.detail}
              </li>
            ))}
          </ol>
          <div class="av-row-between">
            <p class="av-text-soft">Use it daily</p>
            <p class="av-text-soft">Review it weekly</p>
          </div>
        </AvCard>
      </div>
    </AvContainer>
  </section>

  <section class="av-section">
    <AvContainer size="default">
      <div class="av-section-header">
        <h2 class="av-section-title">Why Job Tracker</h2>
        <p class="av-section-lead">A clearer application workflow for people who want search discipline without admin overload.</p>
      </div>
      <div class="av-grid-auto av-grid-auto--260">
        {pillars.map((pillar) => (
          <AvCard variant="soft" className="av-auth-stack-sm av-card--fullheight">
            <h3 class="av-card-heading">{pillar.title}</h3>
            <p class="av-text-soft">{pillar.body}</p>
          </AvCard>
        ))}
      </div>
    </AvContainer>
  </section>

  <section class="av-section">
    <AvContainer size="default">
      <div class="av-section-header">
        <div class="av-kicker"><span>How it works</span></div>
        <h2 class="av-section-title">Add → Update → Review</h2>
        <p class="av-section-lead">Three steps to stay organized from first application to final outcome.</p>
      </div>
      <AvTimeline items={workflowItems} />
    </AvContainer>
  </section>

  <section class="av-section">
    <AvContainer size="default">
      <AvCard variant="soft" className="av-row-between av-card--fullheight">
        <div class="av-auth-stack-xxs">
          <h2 class="av-section-title">Ready to organize your job search?</h2>
          <p class="av-text-soft">Start tracking roles, follow-ups, and outcomes in one pipeline built for clarity.</p>
        </div>
        <AvButton href="/app/job-applications">Open Job Tracker</AvButton>
      </AvCard>
    </AvContainer>
  </section>
</AppShell>
