---
import { buildRootRedirect, getSafeReturnTo } from "../lib/redirects";

const rootAppUrl = Astro.locals.rootAppUrl ?? "https://ansiversa.com";
const fallbackReturnTo = new URL("/", Astro.url).toString();
const returnTo = getSafeReturnTo(Astro.url.searchParams.get("returnTo"), fallbackReturnTo);
const destination = buildRootRedirect(rootAppUrl, "/reset-password", returnTo);
destination;

return Astro.redirect(destination);
---
