---
import {
  AvBreadcrumb,
  AvButton,
  AvCard,
  AvContainer,
  AvEmptyState,
} from "@ansiversa/components";
import { actions } from "astro:actions";
import CreateDrawer from "../../components/drawers/CreateDrawer.astro";
import SettingsDrawer from "../../components/drawers/SettingsDrawer.astro";
import AppShell from "../../layouts/AppShell.astro";
import {
  JOB_APPLICATION_STATUS,
  JOB_APPLICATION_STATUS_LABEL,
  type JobApplicationDTO,
} from "../../modules/job-applications/types";

const FILTERABLE_STATUS = ["all", ...JOB_APPLICATION_STATUS] as const;

const title = "Job Applications – Job Tracker";
const description = "Manage your job application pipeline.";

const result = await Astro.callAction(actions.jobApplications.fetchMyApplications, {
  limit: 200,
});
const data = (result as any)?.data ?? (result as any) ?? {};
const applications = (data?.applications ?? []) as JobApplicationDTO[];

---

<AppShell title={title} description={description}>
  <section class="av-faq-public__crumb">
    <AvContainer>
      <AvBreadcrumb
        items={[
          { label: "Home", href: "/" },
          { label: "Applications" },
        ]}
      />
    </AvContainer>
  </section>

  <section
    class="av-section"
    x-data={`{ statusLabel: ${JSON.stringify(JOB_APPLICATION_STATUS_LABEL)} }`}
  >
    <AvContainer>
      <div
        class="av-auth-stack-lg"
        x-data="$store.jobApplications"
        x-init={`init(${JSON.stringify({ applications })})`}
        @job-app-drawer-open.window="if ($event.detail?.key) { $store.appDrawer.open($event.detail.key) }"
        @job-app-drawer-close.window="$store.appDrawer.close()"
      >
        <AvCard className="av-auth-stack-md">
          <div class="av-row-between">
            <div>
              <p class="av-kicker">Job Tracker</p>
              <h1 class="av-section-title">Your job applications</h1>
              <p class="av-text-soft">Track applications, interviews, follow-ups, and outcomes in one place.</p>
            </div>
            <AvButton type="button" @click="openCreate">Create application</AvButton>
          </div>
          <template x-if="success">
            <p class="av-text-soft" x-text="success"></p>
          </template>
          <template x-if="error">
            <p class="app-form-error" x-text="error"></p>
          </template>
        </AvCard>

        <AvCard variant="soft" className="av-auth-stack-sm">
          <div class="av-row-between">
            <h2 class="av-card-heading">Needs attention</h2>
            <p class="av-text-soft">Stay on top of follow-ups and interviews</p>
          </div>
          <div class="app-needs-grid">
            <div class="av-card av-card-soft app-needs-col av-auth-stack-xs">
              <h3 class="app-subheading">Overdue</h3>
              <template x-if="needsAttention.overdue.length === 0">
                <p class="av-text-soft">No overdue follow-ups.</p>
              </template>
              <template x-if="needsAttention.overdue.length > 0">
                <div class="av-auth-stack-xs">
                  <template x-for="item in needsAttention.overdue" :key="`overdue-${item.id}`">
                    <div class="app-needs-item">
                      <p class="app-needs-item-title"><span x-text="item.companyName"></span> · <span x-text="item.roleTitle"></span></p>
                      <p class="av-text-soft">
                        <span x-text="item.nextActionLabel || 'Follow up'"></span> by <span x-text="item.nextActionDate"></span>
                      </p>
                    </div>
                  </template>
                </div>
              </template>
            </div>

            <div class="av-card av-card-soft app-needs-col av-auth-stack-xs">
              <h3 class="app-subheading">Upcoming interviews</h3>
              <template x-if="needsAttention.upcoming.length === 0">
                <p class="av-text-soft">No interviews in the next 7 days.</p>
              </template>
              <template x-if="needsAttention.upcoming.length > 0">
                <div class="av-auth-stack-xs">
                  <template x-for="item in needsAttention.upcoming" :key="`upcoming-${item.id}`">
                    <div class="app-needs-item">
                      <p class="app-needs-item-title"><span x-text="item.companyName"></span> · <span x-text="item.roleTitle"></span></p>
                      <p class="av-text-soft">Interview on <span x-text="item.interviewDate"></span></p>
                    </div>
                  </template>
                </div>
              </template>
            </div>
          </div>
        </AvCard>

        <AvCard variant="soft" className="av-auth-stack-md">
          <div class="av-row-between">
            <h2 class="av-card-heading">Applications</h2>
            <p class="av-text-soft"><span x-text="visibleApplications.length"></span> shown · <span x-text="applications.length"></span> total</p>
          </div>

          <div class="app-filter-grid">
            <label class="app-field">
              <span class="app-label">Status</span>
              <select class="app-input" x-model="statusFilter">
                {FILTERABLE_STATUS.map((status) => (
                  <option value={status}>
                    {status === "all" ? "All statuses" : JOB_APPLICATION_STATUS_LABEL[status]}
                  </option>
                ))}
              </select>
            </label>
            <label class="app-field">
              <span class="app-label">Search</span>
              <input
                class="app-input"
                type="text"
                x-model="searchQuery"
                placeholder="Company, role, or location"
              />
            </label>
            <label class="app-field">
              <span class="app-label">Sort</span>
              <select class="app-input" x-model="sortBy">
                <option value="updatedDesc">Newest updated</option>
                <option value="updatedAsc">Oldest updated</option>
                <option value="appliedDesc">Applied date (newest first)</option>
                <option value="appliedAsc">Applied date (oldest first)</option>
                <option value="companyAsc">Company name (A–Z)</option>
                <option value="nextActionAsc">Next action date (soonest first)</option>
              </select>
            </label>
          </div>

          <template x-if="applications.length === 0">
            <AvEmptyState
              title="No applications yet"
              description="Create your first application to start tracking your job search."
            />
          </template>

          <template x-if="applications.length > 0 && visibleApplications.length === 0">
            <div class="app-filter-empty av-auth-stack-xs">
              <AvEmptyState
                title="No applications match current filters"
                description="Try a different status, broaden your search, or reset filters."
              />
              <div class="av-row-wrap">
                <AvButton type="button" variant="ghost" @click="resetFilters" :disabled="!hasActiveFilters">Reset filters</AvButton>
              </div>
            </div>
          </template>

          <template x-if="visibleApplications.length > 0">
            <div class="av-auth-stack-sm">
              <template x-for="application in visibleApplications" :key="application.id">
                <div class="av-card av-card-soft app-application-card av-auth-stack-xs">
                  <div class="av-row-between app-row-top">
                    <div>
                      <h3 class="av-card-heading" x-text="application.companyName"></h3>
                      <p class="app-role-line"><span x-text="application.roleTitle"></span></p>
                    </div>
                    <span class="av-badge av-badge-soft">
                      <span x-text="statusLabel[application.status] || application.status"></span>
                    </span>
                  </div>

                  <p class="av-text-soft">Applied on <span class="app-date-text" x-text="application.appliedDate"></span></p>

                  <div class="app-meta-grid">
                    <label class="app-inline-field">
                      <span class="av-text-soft">Status</span>
                      <select
                        :value="application.status"
                        @change="quickUpdateStatus(application.id, $event.target.value)"
                        :disabled="loading"
                        class="app-input"
                      >
                        {JOB_APPLICATION_STATUS.map((status) => (
                          <option value={status}>{JOB_APPLICATION_STATUS_LABEL[status] ?? status}</option>
                        ))}
                      </select>
                    </label>

                    <div class="app-meta-points">
                      <template x-if="application.nextActionDate">
                        <p class="av-text-soft">Next action: <strong x-text="application.nextActionLabel || 'Follow up'"></strong> by <span x-text="application.nextActionDate"></span></p>
                      </template>
                      <template x-if="application.interviewDate">
                        <p class="av-text-soft">Interview date: <span x-text="application.interviewDate"></span></p>
                      </template>
                      <template x-if="application.lastContactDate">
                        <p class="av-text-soft">Last contact: <span x-text="application.lastContactDate"></span></p>
                      </template>
                      <template x-if="application.location">
                        <p class="av-text-soft">Location: <span x-text="application.location"></span></p>
                      </template>
                      <template x-if="application.jobUrl">
                        <p class="av-text-soft">
                          Listing: <a class="app-link" :href="application.jobUrl" target="_blank" rel="noreferrer">Open job URL</a>
                        </p>
                      </template>
                    </div>

                    <template x-if="application.notes">
                      <p class="av-text-soft app-notes">Notes: <span x-text="application.notes"></span></p>
                    </template>
                  </div>

                  <div class="av-row-wrap">
                    <AvButton type="button" variant="ghost" @click="toggleTimeline(application.id)" :disabled="loading">
                      <span x-text="isTimelineExpanded(application.id) ? 'Hide history' : 'View history'"></span>
                    </AvButton>
                    <AvButton type="button" variant="ghost" @click="openEdit(application)" :disabled="loading">Edit</AvButton>
                    <AvButton type="button" variant="ghost" @click="deleteApplication(application.id)" :disabled="loading">Delete</AvButton>
                  </div>

                  <div class="app-timeline" x-show="isTimelineExpanded(application.id)">
                    <h4 class="app-subheading">Timeline</h4>
                    <template x-if="application.events.length === 0">
                      <p class="av-text-soft">No history yet for this application.</p>
                    </template>
                    <template x-if="application.events.length > 0">
                      <div class="av-auth-stack-xs">
                        <template x-for="event in application.events" :key="event.id">
                          <div class="app-timeline-item">
                            <p class="app-timeline-label" x-text="event.eventLabel"></p>
                            <p class="av-text-soft"><span x-text="event.eventDate"></span></p>
                            <template x-if="event.notes">
                              <p class="av-text-soft" x-text="event.notes"></p>
                            </template>
                          </div>
                        </template>
                      </div>
                    </template>
                  </div>
                </div>
              </template>
            </div>
          </template>
        </AvCard>

        <template x-if="$store.appDrawer.activeDrawer === 'create'">
          <CreateDrawer title="Create application" description="Add a new job application entry.">
            <div class="app-form-group av-auth-stack-xs">
              <h3 class="app-subheading">Basic application info</h3>
              <div class="app-form-grid">
                <label class="app-field">
                  <span class="app-label">Company name</span>
                  <input class="app-input" type="text" x-model="form.companyName" maxlength="120" />
                </label>
                <label class="app-field">
                  <span class="app-label">Role title</span>
                  <input class="app-input" type="text" x-model="form.roleTitle" maxlength="120" />
                </label>
                <label class="app-field">
                  <span class="app-label">Status</span>
                  <select class="app-input" x-model="form.status">
                    {JOB_APPLICATION_STATUS.map((status) => (
                      <option value={status}>{JOB_APPLICATION_STATUS_LABEL[status] ?? status}</option>
                    ))}
                  </select>
                </label>
                <label class="app-field">
                  <span class="app-label">Applied date</span>
                  <input class="app-input" type="date" x-model="form.appliedDate" />
                </label>
                <label class="app-field">
                  <span class="app-label">Job URL</span>
                  <input class="app-input" type="url" x-model="form.jobUrl" maxlength="400" placeholder="https://" />
                </label>
                <label class="app-field">
                  <span class="app-label">Location</span>
                  <input class="app-input" type="text" x-model="form.location" maxlength="120" />
                </label>
              </div>
            </div>

            <div class="app-form-group av-auth-stack-xs">
              <h3 class="app-subheading">Tracking and follow-up info</h3>
              <div class="app-form-grid">
                <label class="app-field">
                  <span class="app-label">Interview date</span>
                  <input class="app-input" type="date" x-model="form.interviewDate" />
                </label>
                <label class="app-field">
                  <span class="app-label">Last contact date</span>
                  <input class="app-input" type="date" x-model="form.lastContactDate" />
                </label>
                <label class="app-field">
                  <span class="app-label">Next action date</span>
                  <input class="app-input" type="date" x-model="form.nextActionDate" />
                </label>
                <label class="app-field">
                  <span class="app-label">Next action label</span>
                  <input class="app-input" type="text" x-model="form.nextActionLabel" maxlength="120" placeholder="Follow up" />
                </label>
              </div>
            </div>

            <div class="app-form-group av-auth-stack-xs">
              <h3 class="app-subheading">Notes</h3>
              <label class="app-field">
                <span class="app-label">Notes</span>
                <textarea class="app-input" x-model="form.notes" rows="4" maxlength="2000"></textarea>
              </label>
            </div>
            <div slot="notice">
              <p class="app-form-error" x-show="error" x-text="error"></p>
            </div>
            <div slot="actions" class="av-row-wrap av-drawer-footer-actions">
              <AvButton variant="ghost" type="button" @click="$store.appDrawer.close()" :disabled="loading">Cancel</AvButton>
              <AvButton type="button" @click="submitCreate" :disabled="loading">
                <span x-show="!loading">Create application</span>
                <span x-show="loading">Saving...</span>
              </AvButton>
            </div>
          </CreateDrawer>
        </template>

        <template x-if="$store.appDrawer.activeDrawer === 'settings'">
          <SettingsDrawer title="Edit application" description="Update details, follow-up plan, or status.">
            <div class="app-form-group av-auth-stack-xs">
              <h3 class="app-subheading">Basic application info</h3>
              <div class="app-form-grid">
                <label class="app-field">
                  <span class="app-label">Company name</span>
                  <input class="app-input" type="text" x-model="form.companyName" maxlength="120" />
                </label>
                <label class="app-field">
                  <span class="app-label">Role title</span>
                  <input class="app-input" type="text" x-model="form.roleTitle" maxlength="120" />
                </label>
                <label class="app-field">
                  <span class="app-label">Status</span>
                  <select class="app-input" x-model="form.status">
                    {JOB_APPLICATION_STATUS.map((status) => (
                      <option value={status}>{JOB_APPLICATION_STATUS_LABEL[status] ?? status}</option>
                    ))}
                  </select>
                </label>
                <label class="app-field">
                  <span class="app-label">Applied date</span>
                  <input class="app-input" type="date" x-model="form.appliedDate" />
                </label>
                <label class="app-field">
                  <span class="app-label">Job URL</span>
                  <input class="app-input" type="url" x-model="form.jobUrl" maxlength="400" placeholder="https://" />
                </label>
                <label class="app-field">
                  <span class="app-label">Location</span>
                  <input class="app-input" type="text" x-model="form.location" maxlength="120" />
                </label>
              </div>
            </div>

            <div class="app-form-group av-auth-stack-xs">
              <h3 class="app-subheading">Tracking and follow-up info</h3>
              <div class="app-form-grid">
                <label class="app-field">
                  <span class="app-label">Interview date</span>
                  <input class="app-input" type="date" x-model="form.interviewDate" />
                </label>
                <label class="app-field">
                  <span class="app-label">Last contact date</span>
                  <input class="app-input" type="date" x-model="form.lastContactDate" />
                </label>
                <label class="app-field">
                  <span class="app-label">Next action date</span>
                  <input class="app-input" type="date" x-model="form.nextActionDate" />
                </label>
                <label class="app-field">
                  <span class="app-label">Next action label</span>
                  <input class="app-input" type="text" x-model="form.nextActionLabel" maxlength="120" placeholder="Follow up" />
                </label>
              </div>
            </div>

            <div class="app-form-group av-auth-stack-xs">
              <h3 class="app-subheading">Notes</h3>
              <label class="app-field">
                <span class="app-label">Notes</span>
                <textarea class="app-input" x-model="form.notes" rows="4" maxlength="2000"></textarea>
              </label>
            </div>
            <div slot="notice">
              <p class="app-form-error" x-show="error" x-text="error"></p>
            </div>
            <div slot="actions" class="av-row-wrap av-drawer-footer-actions">
              <AvButton variant="ghost" type="button" @click="$store.appDrawer.close()" :disabled="loading">Cancel</AvButton>
              <AvButton type="button" @click="submitUpdate" :disabled="loading">
                <span x-show="!loading">Save changes</span>
                <span x-show="loading">Saving...</span>
              </AvButton>
            </div>
          </SettingsDrawer>
        </template>
      </div>
    </AvContainer>
  </section>
</AppShell>
